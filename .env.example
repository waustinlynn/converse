# DYNAMODB_TABLE: The name of the Single-Table.
DYNAMODB_TABLE="ConverseApp"
# DYNAMODB_ENDPOINT: Used for local development (http://localhost:8000). Leave empty for AWS.
DYNAMODB_ENDPOINT="http://localhost:8000"
# AWS_REGION: Required for DynamoDB.
AWS_REGION="us-east-1"

# LOG_LEVEL: error, warn, info, debug. Default is info.
LOG_LEVEL="info"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Infrastructure
AWS_REGION=us-east-1

# Cognito (Auth)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_DOMAIN=your-app.auth.us-east-1.amazoncognito.com

# Frontend (Vite) - These must be prefixed with VITE_ to be exposed
VITE_USER_POOL_ID=${COGNITO_USER_POOL_ID}
VITE_USER_POOL_CLIENT_ID=${COGNITO_USER_POOL_CLIENT_ID}
VITE_COGNITO_DOMAIN=${COGNITO_DOMAIN}
VITE_REDIRECT_SIGN_IN=http://localhost:5173
VITE_REDIRECT_SIGN_OUT=http://localhost:5173

# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
